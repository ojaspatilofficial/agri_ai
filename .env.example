# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env file to Git (it's in .gitignore)

# ── Backend Configuration ──────────────────────────────────────────
BACKEND_HOST=localhost
BACKEND_PORT=8000

# ── Frontend Configuration ──────────────────────────────────────────
FRONTEND_HOST=localhost
FRONTEND_PORT=3000

# ── Database Configuration ──────────────────────────────────────────
# Choose your database (PostgreSQL is recommended for production)
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/smart_farming
DATABASE_PATH=./backend/database.sqlite

# ── AI / Ollama Configuration ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest

# ── Weather API ────────────────────────────────────────────────────
# Get free API key from: https://openweathermap.org/api
WEATHER_API_KEY=your_api_key_here

# ── Security ───────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here
SESSION_TIMEOUT=604800

# ── Blockchain Configuration ──────────────────────────────────────
BLOCKCHAIN_LEDGER_PATH=./blockchain/ledger.json

# ── Voice Recognition ─────────────────────────────────────────────
# Uses free Google Speech Recognition by default
# SPEECH_API_KEY=your_speech_api_key_here

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
