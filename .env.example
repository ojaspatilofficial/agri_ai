# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env file to Git (it's in .gitignore)

# Backend Configuration
BACKEND_HOST=localhost
BACKEND_PORT=8000

# Frontend Configuration
FRONTEND_HOST=localhost
FRONTEND_PORT=3000

# Database Configuration
DATABASE_PATH=./backend/database.sqlite

# Weather API (Optional - for real weather data)
# Get free API key from: https://openweathermap.org/api
WEATHER_API_KEY=your_api_key_here

# Security (Optional - will use defaults if not set)
SECRET_KEY=your_secret_key_here
SESSION_TIMEOUT=3600

# Blockchain Configuration
BLOCKCHAIN_LEDGER_PATH=./blockchain/ledger.json

# Voice Recognition (Uses free Google Speech Recognition by default)
# SPEECH_API_KEY=your_speech_api_key_here

# Logging
LOG_LEVEL=INFO

# Groq LLM API Key
# Replace the placeholder with your actual key
GROQ_API_KEY=your_groq_api_key_here
