# ── Core Backend Configuration ──────────────────────────────────────
BACKEND_HOST=localhost
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./backend/database.sqlite
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/db_name

# ── Frontend Configuration ─────────────────────────────────────────
FRONTEND_HOST=localhost
FRONTEND_PORT=3000

# ── Local LLM (Ollama) ─────────────────────────────────────────────
# Download Ollama from: https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest

# ── External AI Vision (Optional) ──────────────────────────────────
# Get API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_key_here
GROK_API_KEY=your_xai_key_here

# ── Weather & Market APIs (Optional for live data) ─────────────────
# Weather: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here
# Market: https://data.gov.in/
DATA_GOV_IN_API_KEY=your_datagov_key_here

# ── Other Settings ──────────────────────────────────────────────────
SECRET_KEY=generate_a_random_string_here
SESSION_TIMEOUT=604800
LOG_LEVEL=INFO
